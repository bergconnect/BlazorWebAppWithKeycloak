@page "/hello-world"
@rendermode InteractiveServer
@inject HelloWorldApiClient ApiClient

<PageTitle>Hello World API</PageTitle>

<h1>Hello World API</h1>
<p class="lead">Aanroep naar de <code>BlazorWebAppWithKeycloak.API</code>.</p>

<AuthorizeView>
    <Authorized>
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="RoepAanAsync" disabled="@_bezig">
                @if (_bezig)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                API aanroepen
            </button>
        </div>

        @if (_fout is not null)
        {
            <div class="alert alert-danger" role="alert">
                <strong>Fout:</strong> @_fout
            </div>
        }
        else if (_response is not null)
        {
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <strong>Response</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Bericht</dt>
                        <dd class="col-sm-9">@_response.Message</dd>

                        <dt class="col-sm-3">Tijdstip</dt>
                        <dd class="col-sm-9">@_response.Timestamp.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</dd>
                    </dl>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToNotLoggedIn />
    </NotAuthorized>
</AuthorizeView>

@code {
    private HelloWorldResponse? _response;
    private string? _fout;
    private bool _bezig;

    protected override async Task OnInitializedAsync()
        => await RoepAanAsync();

    private async Task RoepAanAsync()
    {
        _bezig = true;
        _fout = null;
        _response = null;

        try
        {
            _response = await ApiClient.GetHelloAsync();
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 401)
        {
            _fout = "Niet geautoriseerd — uw sessie is mogelijk verlopen.";
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 403)
        {
            _fout = "Toegang geweigerd — u heeft de 'user' rol nodig.";
        }
        catch (Exception ex)
        {
            _fout = $"API niet bereikbaar: {ex.Message}";
        }
        finally
        {
            _bezig = false;
        }
    }
}
