@page "/admin"
@rendermode InteractiveServer
@inject HelloWorldApiClient ApiClient

<PageTitle>Admin API</PageTitle>

<h1>Admin API</h1>
<p class="lead">Aanroep naar het beveiligde beheereindpunt van de <code>BlazorWebAppWithKeycloak.API</code>.</p>

<AuthorizeView>
    <Authorized>
        <AuthorizeView Roles="admin" Context="adminContext">
            <Authorized>
                <div class="mb-3">
                    <button class="btn btn-danger" @onclick="RoepAanAsync" disabled="@_bezig">
                        @if (_bezig)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        Admin API aanroepen
                    </button>
                </div>

                @if (_fout is not null)
                {
                    <div class="alert alert-danger" role="alert">
                        <strong>Fout:</strong> @_fout
                    </div>
                }
                else if (_response is not null)
                {
                    <div class="card border-danger">
                        <div class="card-header bg-danger text-white">
                            <strong>Response</strong>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Bericht</dt>
                                <dd class="col-sm-9">@_response.Message</dd>

                                <dt class="col-sm-3">Tijdstip</dt>
                                <dd class="col-sm-9">@_response.Timestamp.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</dd>
                            </dl>
                        </div>
                    </div>
                }
            </Authorized>
            <NotAuthorized Context="notAdminContext">
                <div class="alert alert-warning" role="alert">
                    <strong>Toegang geweigerd.</strong> U heeft de <code>admin</code> rol nodig om dit endpoint te benaderen.
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </Authorized>
    <NotAuthorized>
        <RedirectToNotLoggedIn />
    </NotAuthorized>
</AuthorizeView>

@code {
    private HelloWorldResponse? _response;
    private string? _fout;
    private bool _bezig;

    protected override async Task OnInitializedAsync()
        => await RoepAanAsync();

    private async Task RoepAanAsync()
    {
        _bezig = true;
        _fout = null;
        _response = null;

        try
        {
            _response = await ApiClient.GetAdminAsync();
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 401)
        {
            _fout = "Niet geautoriseerd — uw sessie is mogelijk verlopen.";
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 403)
        {
            _fout = "Toegang geweigerd — u heeft de 'admin' rol nodig.";
        }
        catch (Exception ex)
        {
            _fout = $"API niet bereikbaar: {ex.Message}";
        }
        finally
        {
            _bezig = false;
        }
    }
}
